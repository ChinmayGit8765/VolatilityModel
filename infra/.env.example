# VolForecast local infrastructure — environment variable template
#
# Copy this file to infra/.env and fill in real credentials.
# NEVER commit infra/.env to git (it is gitignored).
#
# Usage:
#   cp infra/.env.example infra/.env
#   # Edit the values below, then:
#   docker compose -f infra/docker-compose.yml --env-file infra/.env up -d

# Postgres credentials shared by both MLflow and Prefect backend stores.
# MLflow connects to POSTGRES_DB; Prefect uses a separate 'prefectdb' database
# within the same Postgres instance (created automatically on first Prefect start).
POSTGRES_USER=your_pg_user
POSTGRES_PASSWORD=your_pg_password_here
POSTGRES_DB=mlflowdb
